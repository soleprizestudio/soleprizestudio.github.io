---
import { Icon } from 'astro-icon/components';
import type { MarkdownHeading } from 'astro';

export interface Props {
  headings?: MarkdownHeading[];
  class?: string;
  variant?: 'mobile' | 'desktop';
}

const { headings = [], class: className = '', variant = 'desktop' } = Astro.props;
const items = headings.filter((h) => h.depth >= 2 && h.depth <= 3);

const actions = [
  { action: 'top', icon: 'tabler:arrow-up', text: '맨 위로' },
  { action: 'comments', icon: 'tabler:message-circle', text: '댓글로 이동' },
  { action: 'copy', icon: 'tabler:link', text: '링크 복사' },
] as const;
---

{
  (
    <div class:list={['not-prose text-sm', className]}>
      {variant === 'mobile' ? (
        <details class="rounded-lg border border-gray-200 dark:border-slate-700 px-4 py-3">
          <summary class="cursor-pointer font-medium">목차</summary>
          <nav class="mt-3">
            {items.length > 0 ? (
              <ul class="space-y-2">
                {items.map((h) => (
                  <li class:list={[h.depth === 3 && 'ml-4']}>
                    <a href={`#${h.slug}`} class="text-muted hover:text-primary hover:underline">
                      {h.text}
                    </a>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="text-muted">목차가 없습니다.</p>
            )}
          </nav>
          <div class="mt-4 flex flex-col gap-2 border-t dark:border-slate-700 pt-3">
            {actions.map(({ action, icon, text }) => (
              <button
                type="button"
                data-toc-action={action}
                class="flex items-center gap-2 text-muted hover:text-primary text-left"
              >
                <Icon name={icon} class="w-4 h-4" />
                <span data-toc-label={action === 'copy' ? '' : undefined}>{text}</span>
              </button>
            ))}
          </div>
        </details>
      ) : (
        <div class="sticky top-24">
          {items.length > 0 && (
            <>
              <p class="font-medium mb-3">목차</p>
              <nav>
                <ul class="space-y-2 border-l dark:border-slate-700">
                  {items.map((h) => (
                    <li class:list={[h.depth === 3 && 'ml-4']}>
                      <a
                        href={`#${h.slug}`}
                        class="block border-l-2 border-transparent -ml-px pl-3 text-muted hover:text-primary hover:border-primary"
                      >
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </>
          )}
          <div class:list={['flex flex-col gap-3', { 'mt-6 border-t dark:border-slate-700 pt-4': items.length > 0 }]}>
            {actions.map(({ action, icon, text }) => (
              <button
                type="button"
                data-toc-action={action}
                class="flex items-center gap-2 text-muted hover:text-primary text-left"
              >
                <Icon name={icon} class="w-4 h-4" />
                <span data-toc-label={action === 'copy' ? '' : undefined}>{text}</span>
              </button>
            ))}
          </div>
        </div>
      )}
    </div>
  )
}

<script>
  const COPY_LABEL = '링크 복사';
  const COPIED_LABEL = '복사됨!';

  const boundButtons = new WeakSet<Element>();

  function initTocActions() {
    document.querySelectorAll<HTMLButtonElement>('[data-toc-action]').forEach((button) => {
      if (boundButtons.has(button)) return;
      boundButtons.add(button);

      button.addEventListener('click', () => {
        const action = button.dataset.tocAction;

        if (action === 'top') {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        } else if (action === 'comments') {
          document.getElementById('comments')?.scrollIntoView({ behavior: 'smooth' });
        } else if (action === 'copy') {
          navigator.clipboard
            .writeText(window.location.href)
            .then(() => {
              const label = button.querySelector('[data-toc-label]');
              if (!label) return;
              label.textContent = COPIED_LABEL;
              setTimeout(() => {
                label.textContent = COPY_LABEL;
              }, 1500);
            })
            .catch(() => {});
        }
      });
    });
  }

  initTocActions();
  document.addEventListener('astro:page-load', initTocActions);
</script>

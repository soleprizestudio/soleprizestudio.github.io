---
import Layout from '~/layouts/PageLayout.astro';
import Features from '~/components/widgets/Features.astro';

const metadata = { title: '앱' };
---

<Layout metadata={metadata}>
  <section class="px-4 pt-16 sm:px-6 mx-auto lg:px-8 lg:pt-20 max-w-6xl">
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4">앱</h1>
    <p class="text-muted mb-4">SolePrize Studio가 만드는 앱을 소개합니다.</p>
  </section>

  <Features
    columns={2}
    items={[
      {
        title: '앱 이름',
        description: '짧은 설명이 여기 들어갑니다. 실제 앱 정보로 교체해주세요.',
        icon: 'tabler:apps',
        callToAction: {
          text: '스토어에서 보기',
          href: '#',
        },
      },
    ]}
  />
</Layout>

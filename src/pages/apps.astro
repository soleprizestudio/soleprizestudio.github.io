---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features from '~/components/widgets/Features.astro';

const metadata = { title: '앱' };
---

<Layout metadata={metadata}>
  <HeroText tagline="Apps" title="앱" subtitle="SolePrize Studio가 만드는 앱을 소개합니다." />

  <Features
    columns={2}
    items={[
      {
        title: '앱 이름',
        description: '짧은 설명이 여기 들어갑니다. 실제 앱 정보로 교체해주세요.',
        icon: 'tabler:apps',
        callToAction: {
          text: '스토어에서 보기',
          href: '#',
        },
      },
    ]}
  />
</Layout>

---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features from '~/components/widgets/Features.astro';
import { getCollection } from 'astro:content';
import { getPermalink } from '~/utils/permalinks';

const apps = await getCollection('apps', ({ data }) => !data.draft);

const metadata = { title: '앱' };
---

<Layout metadata={metadata}>
  <HeroText tagline="Apps" title="앱" subtitle="SolePrize Studio가 만드는 앱을 소개합니다." />

  <Features
    columns={2}
    items={apps.map((app) => ({
      title: app.data.title,
      description: app.data.description,
      icon: app.data.icon || 'tabler:apps',
      image: app.data.iconImage ? { src: app.data.iconImage, alt: `${app.data.title} 아이콘` } : undefined,
      callToAction: {
        text: '자세히 보기',
        href: getPermalink(`/apps/${app.id}`),
      },
    }))}
  />
</Layout>

---
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Layout from '~/layouts/PageLayout.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: '소개',
};
---

<Layout metadata={metadata}>
  <Hero tagline="About">
    <Fragment slot="title">소개</Fragment>
    <Fragment slot="subtitle">앱과 게임을 만드는 스튜디오, SolePrize Studio입니다.</Fragment>
  </Hero>

  <Content
    title="SolePrize Studio"
    items={[
      {
        title: '누구인가요',
        description:
          "안녕하세요, '평범한 개발자'를 줄여 평발이라는 닉네임을 쓰고 있습니다. SolePrize Studio는 제가 혼자 운영하는 1인 스튜디오입니다. 만들고 싶은 아이디어가 떠오르면 사이드 프로젝트로 하나씩 앱과 게임을 만들어가고 있습니다.",
      },
      {
        title: '무엇을 만드나요',
        description:
          '일상에서 조금이라도 도움이 될 만한 앱과, 부담 없이 즐길 수 있는 게임을 만듭니다. 화려하진 않아도 꾸준히, 하나씩 완성해 나가는 것을 목표로 하고 있습니다.',
      },
      {
        title: '문의',
        description: `궁금한 점이나 제안하고 싶은 아이디어가 있다면 <a href="${getPermalink('/contact')}" class="text-primary font-medium hover:underline">문의 페이지</a>로 편하게 연락 주세요.`,
      },
    ]}
  />
</Layout>
